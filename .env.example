# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the populated version.

# Azure Blob Storage — obtain from Azure Portal:
#   Storage Account → Security + networking → Access keys → key1 → Connection string
AZURE_STORAGE_CONNECTION_STRING=

# Container names (created in Azure Portal)
AZURE_INPUT_CONTAINER=pdfinput
AZURE_OUTPUT_CONTAINER=pdfoutput
