# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the populated version.

# Azure Blob Storage — obtain from Azure Portal:
#   Storage Account → Security + networking → Access keys → key1 → Connection string
AZURE_STORAGE_CONNECTION_STRING=

# Container names (created in Azure Portal)
AZURE_INPUT_CONTAINER=pdfinput
AZURE_OUTPUT_CONTAINER=pdfoutput

# Azure OpenAI — used for opt-in checkbox extraction (opt_in_extractor.py)
# Obtain from Azure Portal: Azure OpenAI resource -> Keys and Endpoint
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
