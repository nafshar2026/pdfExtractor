# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the populated version.

# Azure Blob Storage — obtain from Azure Portal:
#   Storage Account → Security + networking → Access keys → key1 → Connection string
AZURE_STORAGE_CONNECTION_STRING=

# Container names (created in Azure Portal)
AZURE_INPUT_CONTAINER=pdfinput
AZURE_OUTPUT_CONTAINER=pdfoutput

# Azure OpenAI — used for opt-in checkbox extraction (opt_in_extractor.py)
# Obtain from Azure Portal: Azure OpenAI resource -> Keys and Endpoint
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# PDF processing settings
# Windowed chunking: always enabled; this controls pages per chunk (default 20)
PDF_EXTRACTOR_OVERLAP_CHUNK_PAGES=20

# OCR hardening (recommended profile for large scanned files)
PDF_EXTRACTOR_OCR_ISOLATED=1
PDF_EXTRACTOR_OCR_RECYCLE_CALLS=4
PDF_EXTRACTOR_OCR_POOL_RETRIES=4
PDF_EXTRACTOR_OCR_MAX_WIDTH=900
